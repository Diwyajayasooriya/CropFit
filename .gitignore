# Create .gitignore file
cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.so
.Python
env/
venv/
.env
.venv
*.log
*.pid
*.seed
*.sqlite

# FastAPI
*.db

# Node / Next.js
node_modules/
.next/
out/
build/
dist/
*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment
.env
.env.local
.env.production

# ML models (large files)
*.h5
*.pkl
*.joblib
*.pb

# Reports
*.pdf
*.xlsx

# Testing
.coverage
.pytest_cache/
htmlcov/
EOF